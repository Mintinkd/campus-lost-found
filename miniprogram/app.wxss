page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.btn-primary {
  background: #07C160;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #07C160;
  border: 2rpx solid #07C160;
  border-radius: 12rpx;
  padding: 18rpx 38rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-danger {
  background: #fff;
  color: #FA5151;
  border: 2rpx solid #FA5151;
  border-radius: 12rpx;
  padding: 18rpx 38rpx;
  font-size: 32rpx;
  text-align: center;
}

.tag {
  display: inline-block;
  background: #E8F5E9;
  color: #07C160;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-warning {
  background: #FFF3E0;
  color: #FF9800;
}

.tag-danger {
  background: #FFEBEE;
  color: #FA5151;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.text-secondary {
  color: #999;
  font-size: 26rpx;
}

.text-primary {
  color: #07C160;
}

.text-danger {
  color: #FA5151;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-state .icon {
  font-size: 120rpx;
  color: #ccc;
  margin-bottom: 20rpx;
}

.empty-state .text {
  color: #999;
  font-size: 28rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.match-score {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #07C160, #00BFA5);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-pending {
  background: #FFF3E0;
  color: #FF9800;
}

.status-claiming {
  background: #E3F2FD;
  color: #1976D2;
}

.status-returned {
  background: #E8F5E9;
  color: #07C160;
}

.status-expired {
  background: #F5F5F5;
  color: #999;
}