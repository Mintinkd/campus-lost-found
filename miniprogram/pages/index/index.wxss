.header {
  padding: 20rpx;
}

.header-card {
  background: linear-gradient(135deg, #07C160, #00BFA5);
  border-radius: 24rpx;
  padding: 40rpx;
  color: #fff;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 32rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: 26rpx;
  color: #fff;
}

.section {
  padding: 0 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.item-photo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.item-photo image {
  width: 100%;
  height: 100%;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-category {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-location {
  font-size: 28rpx;
  color: #666;
}

.item-time {
  font-size: 24rpx;
}