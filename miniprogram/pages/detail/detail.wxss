.photo-swiper swiper {
  height: 400rpx;
}

.photo-swiper image {
  width: 100%;
  height: 400rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.action-area {
  margin-top: 20rpx;
}

.claim-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.claim-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.claim-user {
  font-size: 28rpx;
  font-weight: 500;
}

.claim-reason {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.claim-actions {
  display: flex;
  gap: 16rpx;
}

.claim-btn {
  font-size: 26rpx;
  padding: 10rpx 24rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  z-index: 101;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

.claim-textarea {
  width: 100%;
  min-height: 200rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
}