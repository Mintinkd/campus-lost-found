.profile-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #e0e0e0;
}

.profile-info {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
}

.campus {
  font-size: 24rpx;
}

.phone-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: #07C160;
  color: #fff;
  border-radius: 20rpx;
  border: none;
}

.phone-btn::after {
  border: none;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.tab-active {
  color: #07C160;
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #07C160;
  border-radius: 2rpx;
}

.list-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.list-item-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.list-item-location {
  font-size: 26rpx;
  color: #666;
}

.notif-title {
  font-size: 28rpx;
  font-weight: 500;
}