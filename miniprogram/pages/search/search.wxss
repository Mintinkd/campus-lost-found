.search-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

.search-btn {
  background: #07C160;
  color: #fff;
  border-radius: 40rpx;
  padding: 0 32rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.parse-result {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.parse-label {
  font-size: 26rpx;
  color: #666;
}

.loading {
  text-align: center;
  padding: 80rpx;
  color: #999;
}

.result-count {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.result-card {
  margin-bottom: 16rpx;
}

.result-header {
  display: flex;
  gap: 20rpx;
}

.result-photo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.result-photo image {
  width: 100%;
  height: 100%;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-category {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.result-location {
  font-size: 28rpx;
  color: #666;
}

.result-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.history-section {
  margin-top: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
}

.history-icon {
  font-size: 28rpx;
}

.history-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}