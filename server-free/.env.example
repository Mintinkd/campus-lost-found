# ===== 数据库配置 =====
# SQLite (本地开发)
DB_DIALECT=sqlite
DB_STORAGE=./data/campus_lost_found.db

# PostgreSQL (生产部署 - Neon/Render)
# DB_DIALECT=postgres
# DB_HOST=ep-xxx.us-east-2.aws.neon.tech
# DB_PORT=5432
# DB_NAME=campus_lost_found
# DB_USER=neondb_owner
# DB_PASS=your-password
# DB_SSL=true

# ===== AI 图像识别 =====
RECOGNITION_PROVIDER=tensorflow

# ===== 通知推送 =====
NOTIFICATION_PROVIDER=email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="校园失物招领 <your-email@gmail.com>"

# ===== 文件上传 =====
UPLOAD_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ===== 认证 =====
AUTH_PROVIDER=local
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_EXPIRES_IN=7d

# ===== 加密 =====
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
ENCRYPTION_IV=0123456789abcdef

# ===== 跨域 =====
CORS_ORIGIN=*
SITE_URL=http://localhost:3000
